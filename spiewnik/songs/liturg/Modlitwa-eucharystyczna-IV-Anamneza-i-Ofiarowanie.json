      ],
      "text": [
        "Boże, Ojcze,",
        "sprawując teraz pamiątkę naszego odkupienia,",
        "wspominamy śmierć Chrystusa",
        "i Jego zstąpienie do otchłani,",
        "wyznajemy Jego zmartwychwstanie",
        "i wstąpienie do nieba,",
        "a oczekując Jego przyjścia w chwale,",
        "składamy Ci, Boże, Jego Ciało i Krew",
        "jako Ofiarę miłą Tobie i zbawienną dla całego świata."
      ]
